PORT=3001
BASE_URL=https://tasket-auth.up.railway.app
FRONTEND_URL=https://your-frontend.vercel.app

DATABASE_URL=postgresql://user:password@host/tasket_auth?sslmode=require

# RS256 keys — already generated, paste your values here
JWT_PRIVATE_KEY=YOUR_BASE64_PRIVATE_KEY
JWT_PUBLIC_KEY=YOUR_BASE64_PUBLIC_KEY
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY_DAYS=30

# Google OAuth — from console.cloud.google.com
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
